{
  "name": "waraq-extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite --mode web",
    "build": "tsc -b && vite build",
    "build:web": "tsc -b && vite build --mode web",
    "preview": "vite preview",
    "preview:web": "vite preview --outDir dist-web",
    "lint": "eslint .",
    "package": "node scripts/package.mjs --build",
    "package:zip": "node scripts/package.mjs"
  },
  "dependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@tanstack/react-virtual": "^3.13.23",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.0",
    "fuse.js": "^7.3.0",
    "idb": "^8.0.3",
    "katex": "^0.16.45",
    "lucide-react": "^1.8.0",
    "mermaid": "^11.14.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-directive": "^4.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/chrome": "^0.1.40",
    "@types/dompurify": "^3.0.5",
    "@types/katex": "^0.16.8",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
